{
  "name": "adult-day-operations-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:turbo",
    "dev:turbo": "npm run port:kill && next dev --turbopack -p 3001",
    "dev:turbo:clean": "npm run port:kill && npm run clean:next && next dev --turbopack -p 3001",
    "dev:webpack": "npm run port:kill && npm run clean:next && next dev --webpack -p 3001",
    "dev:webpack:clean": "npm run dev:webpack",
    "dev:mem": "npm run port:kill && npm run clean:next && node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev -p 3001",
    "dev:mem:turbo": "npm run port:kill && npm run clean:next && node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack -p 3001",
    "port:kill": "node scripts/kill-port.cjs 3001",
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{ recursive: true, force: true })\"",
    "dev:clean": "npm run dev:turbo:clean",
    "prepare": "node scripts/setup-git-hooks.cjs",
    "build": "npm run build:turbo",
    "build:webpack": "node scripts/build-webpack.cjs",
    "build:turbo": "node scripts/build-turbo.cjs",
    "audit:module-sizes": "node scripts/audit-module-sizes.cjs",
    "db:push": "supabase db push",
    "db:push:local": "supabase db push --local",
    "db:types": "node scripts/generate-supabase-types.cjs --linked",
    "db:types:local": "node scripts/generate-supabase-types.cjs --local",
    "db:sync": "npm run db:push && npm run db:types",
    "db:check": "node scripts/check-db-sync.cjs",
    "prepush": "npm run db:check && npm run typecheck",
    "supabase:db:push": "npm run db:push",
    "supabase:db:push:local": "npm run db:push:local",
    "supabase:types:linked": "npm run db:types",
    "supabase:types:local": "npm run db:types:local",
    "dev:full": "npm run db:sync && npm run dev",
    "fix-prompts:generate": "tsx scripts/generate-fix-prompt-report.ts",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.typecheck.json",
    "test:payroll": "tsx --test tests/payroll/**/*.test.ts",
    "quality:gates": "node scripts/quality-gates/run.cjs",
    "seed": "tsx scripts/seed-supabase.ts",
    "reseed": "tsx scripts/seed-supabase.ts --reset",
    "seed:intake": "tsx scripts/seed-supabase.ts --module intake",
    "seed:sales": "tsx scripts/seed-supabase.ts --module sales",
    "seed:attendance": "tsx scripts/seed-supabase.ts --module attendance",
    "seed:health": "tsx scripts/seed-supabase.ts --module intake --module attendance",
    "backfill:member-files": "node -r ./scripts/shim-server-only.cjs ./node_modules/tsx/dist/cli.mjs scripts/backfill-member-file-storage.ts",
    "repair:historical-drift": "node --loader ./scripts/server-only-loader.mjs -r ./scripts/shim-server-only.cjs ./node_modules/tsx/dist/cli.mjs scripts/repair-historical-drift.ts",
    "repair:billing-quickbooks": "node -r ./scripts/shim-server-only.cjs ./node_modules/tsx/dist/cli.mjs scripts/repair-billing-quickbooks-customers.ts",
    "repair:enrollment-packet-completions": "node --loader ./scripts/server-only-loader.mjs -r ./scripts/shim-server-only.cjs ./node_modules/tsx/dist/cli.mjs scripts/repair-enrollment-packet-completions.ts",
    "e2e:pof-sign:live": "node --loader ./scripts/server-only-loader.mjs -r ./scripts/shim-server-only.cjs ./node_modules/tsx/dist/cli.mjs scripts/e2e-pof-signing-live.ts",
    "e2e:enrollment-packet:live": "node --loader ./scripts/server-only-loader.mjs -r ./scripts/shim-server-only.cjs ./node_modules/tsx/dist/cli.mjs scripts/e2e-enrollment-packet-live.ts",
    "migrate:mock-to-supabase": "tsx scripts/seed-supabase.ts --legacy-only",
    "migrate:mock-to-supabase:reset": "tsx scripts/seed-supabase.ts --legacy-only --reset"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.99.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "next": "^16.2.1",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^4.8.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.3",
    "supabase": "^2.84.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
