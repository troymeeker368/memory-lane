# Runtime mode
# true  => local mock mode (no Supabase credentials required)
# false => real backend mode (requires Supabase URL + anon key)
NEXT_PUBLIC_USE_MOCK_DATA=true

# Optional in mock mode: controls role-based UI visibility
NEXT_PUBLIC_MOCK_ROLE=manager

# Required only when NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional now; used later for admin/server integrations
SUPABASE_SERVICE_ROLE_KEY=

# Optional external link
NEXT_PUBLIC_PTO_URL=https://example-hr-portal.com/pto
